# Exemple de fichier .env pour le backend.
# Utilisé UNIQUEMENT si tu lances le backend en local SANS docker-compose.
# Avec docker-compose, les variables sont injectées directement dans le container.

PORT=5001
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cosmetic_lab
DB_PORT=5432

# Doit être une chaîne longue et aléatoire (au moins 32 caractères).
# Sert à signer les tokens JWT. À ne JAMAIS partager ni commiter.
JWT_SECRET=remplace_moi_par_une_vraie_chaine_aleatoire_longue
